# Database (Neon Postgres via Vercel Marketplace — vercel integration add neon)
DATABASE_URL=
# Vercel may also inject POSTGRES_URL from the Neon integration

# Auth
JWT_SECRET=

# Frontend (local dev only — production uses same-origin /api)
VITE_API_URL=http://localhost:8000/api

# Revolut Business API (bank transfers → /api/webhooks/revolut)
REVOLUT_CLIENT_ID=
REVOLUT_REDIRECT_URI=https://your-app.vercel.app/api/revolut/callback
REVOLUT_API_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_BUSINESS_BASE_URL=https://sandbox-b2b.revolut.com
REVOLUT_SOURCE_ACCOUNT_ID=

# Weekly payout (Friday → committee BoC via Revolut Business /pay)
PAYOUT_MIN_AMOUNT=50
PAYOUT_TIMEZONE=Asia/Nicosia

# Notifications
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+357XXXXXXXX

# Vercel Cron (Authorization: Bearer <CRON_SECRET> on scheduled requests)
CRON_SECRET=

# CORS (optional — VERCEL_URL is applied automatically when deployed)
FRONTEND_URL=http://localhost:5173
