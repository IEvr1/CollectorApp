# Supabase
SUPABASE_URL=supabase.co
SUPABASE_SERVICE_ROLE_KEY=https://your-project.supabase.co
SUPABASE_JWT_SECRET=https://your-project.supabase.co

# Frontend (copy to frontend/.env)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:8000

# AI (Phase 2)
ANTHROPIC_API_KEY=

# Revolut Business API (bank transfers → /webhooks/revolut)
REVOLUT_CLIENT_ID=p40
REVOLUT_REDIRECT_URI=http://localhost:8000/revolut/callback
REVOLUT_API_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_BUSINESS_BASE_URL=https://sandbox-b2b.revolut.com
REVOLUT_SOURCE_ACCOUNT_ID=

# Weekly payout (Friday → committee BoC via Revolut Business /pay)
PAYOUT_MIN_AMOUNT=50
PAYOUT_TIMEZONE=Asia/Nicosia

# Notifications
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+357XXXXXXXX

# Cron (Phase 2)
RAILWAY_CRON_SECRET=

# CORS
FRONTEND_URL=http://localhost:5173
