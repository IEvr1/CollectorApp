{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "backend/server.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-payout",
      "schedule": "0 4 * * 5"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
